{
  "name": "nova-spire",
  "version": "0.1.0",
  "description": "Nova Spire — a data-driven roguelike deckbuilder built with TypeScript, PixiJS and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "subset-font": "python3 scripts/subset_font.py"
  },
  "keywords": ["roguelike", "deckbuilder", "pixijs", "typescript", "game"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "pixi.js": "^8.2.6"
  }
}
